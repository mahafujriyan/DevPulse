# Server
PORT=5000
NODE_ENV=development

# Supabase Session Pooler (required for Vercel — port 6543, NOT 5432)
# Supabase → Settings → Database → Connection string → Session pooler → URI
DATABASE_URL=postgresql://postgres.qwrbhzbvfnojvxoshvse:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Local pgAdmin
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/devpulse

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── VERCEL DASHBOARD (Settings → Environment Variables) ─────────────────────
# Copy the SAME values from your local .env:
#   DATABASE_URL   = Session pooler URI (port 6543)
#   JWT_SECRET     = your secret
#   JWT_EXPIRES_IN = 7d
#   NODE_ENV       = production
