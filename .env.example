# Server
PORT=5000
NODE_ENV=development

# ─── Supabase (recommended for hosted development) ────────────────────────────
# Dashboard → Project Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your database password (NOT the publishable API key)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.qwrbhzbvfnojvxoshvse.supabase.co:5432/postgres

# Session pooler (use if direct connection has network issues)
# DATABASE_URL=postgresql://postgres.qwrbhzbvfnojvxoshvse:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ─── Local pgAdmin ───────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/devpulse

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
