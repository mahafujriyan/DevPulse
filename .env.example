# Server
PORT=5000
NODE_ENV=development

# PostgreSQL — use ONE of these setups:

# Local pgAdmin / PostgreSQL
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/devpulse

# Supabase (Project Settings → Database → Connection string → URI)
# Replace [YOUR-PASSWORD] with your database password
# DATABASE_URL=postgresql://postgres.qwrbhzbvfnojvxoshvse:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres
# JWT (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d
