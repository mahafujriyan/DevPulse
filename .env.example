# Server
PORT=5000
NODE_ENV=development

# Supabase Session Pooler (required for Vercel — port 6543)
DATABASE_URL=postgresql://postgres.qwrbhzbvfnojvxoshvse:YOUR_PASSWORD@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres

# Local pgAdmin (backup)
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/devpulse

JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── VERCEL: Settings → Environment Variables ─────────────────────────────────
# DATABASE_URL  = (same Session pooler URI as above)
# JWT_SECRET    = (long random string)
# JWT_EXPIRES_IN = 7d
# NODE_ENV      = production
