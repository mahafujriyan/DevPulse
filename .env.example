# Server
PORT=5000
NODE_ENV=development

# ─── Supabase (local) ─────────────────────────────────────────────────────────
# Password e @ thakle URL encode koro (@ → %40)
# DATABASE_URL=postgresql://postgres:YOUR_ENCODED_PASSWORD@db.qwrbhzbvfnojvxoshvse.supabase.co:5432/postgres

# ─── Supabase Session Pooler (recommended for Vercel production) ────────────────
# DATABASE_URL=postgresql://postgres.qwrbhzbvfnojvxoshvse:YOUR_ENCODED_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# ─── Local pgAdmin ────────────────────────────────────────────────────────────
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/devpulse

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ─── Vercel Dashboard (Settings → Environment Variables) ────────────────────────
# Add these in Vercel — .env file is NOT uploaded to production:
#   DATABASE_URL  = (Supabase pooler URI with encoded password)
#   JWT_SECRET    = (same as local or new random string)
#   JWT_EXPIRES_IN = 7d
#   NODE_ENV      = production
